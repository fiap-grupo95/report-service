# report-service — variáveis de ambiente
# Copie para .env e preencha os valores obrigatórios

PORT=8083

# MongoDB
MONGO_USER=report
MONGO_PASSWORD=
MONGO_DB=reports

# RabbitMQ (painel disponível em localhost:15674)
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=

# Filas e tópicos
REPORT_QUEUE=report.queue
REPORT_TOPIC=report.topic
